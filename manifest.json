{
  "manifest_version": 3,
  "name": "京东Cookie提取器",
  "version": "1.0",
  "description": "从京东网站提取登录凭证 pt_key 和 pt_pin",
  "permissions": ["tabs", "cookies", "activeTab"],
  "host_permissions": ["*://*.jd.com/*", "*://*.jd.com/"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  }
}